# Copy to .env and fill in your values
# Get LITELLM_API_KEY from: printenv LITELLM_MASTER_KEY
LITELLM_API_KEY=your-litellm-master-key-here

# AI assistant model (served via the local LiteLLM proxy)
AI_MODEL=gpt-5
# Comma-separated fallback models tried if the primary upstream flaps
AI_FALLBACKS=gemini-2.5-flash,gpt-5.5
# Fail fast (ms) instead of hanging the browser when an upstream stalls
AI_TIMEOUT_MS=30000
